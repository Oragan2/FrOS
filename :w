ENTRY(_start)

SECTIONS
{
    /* Tell the linker the kernel will live at physical address 0x7E00 */
    . = 0x7E00;

    .text : {
        *(.entry)       /* CRITICAL: Force kernel_entry.o to be at the absolute front */
        *(.text)        /* All other C and assembly code follows */
    }

    .data : {
        *(.data)
        *(.rodata*)
    }

    .bss : {
        *(.bss)
    }
}
